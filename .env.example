# ─── AI Provider ─────────────────────────────────────────────────────
# Which AI provider to use. Only "anthropic" is implemented today.
# ("gemini" is a stub and will throw — leave this as anthropic.)
MODEL_PROVIDER=anthropic

# Anthropic API key (required — used for onboarding + the Strategic insights narrative)
ANTHROPIC_API_KEY=

# Google Gemini API key (reserved for future use; the gemini provider is not implemented yet)
GEMINI_API_KEY=

# ─── Scraping ────────────────────────────────────────────────────────
# Max ads to scrape per competitor per run (default: 50)
SCRAPE_MAX_ADS_PER_RUN=50

# Default country for CLI scraping (default: US)
SCRAPE_COUNTRY=US

# ─── Demo Mode ───────────────────────────────────────────────────────
# Set to "true" for the deployed Vercel demo (disables all writes)
DEMO_MODE=false

# ─── Database ────────────────────────────────────────────────────────
# Optional: override SQLite path (default: ./data/app.db)
# DATABASE_URL=./data/app.db
