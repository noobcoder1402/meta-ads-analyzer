# ─── AI Provider ─────────────────────────────────────────────────────
# Which AI provider to use: "anthropic" (default) or "gemini"
MODEL_PROVIDER=gemini

# Anthropic API key (required if MODEL_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Google Gemini API key (required if MODEL_PROVIDER=gemini)
GEMINI_API_KEY=

# ─── Scraping ────────────────────────────────────────────────────────
# Max ads to scrape per competitor per run (default: 50)
SCRAPE_MAX_ADS_PER_RUN=50

# Default country for CLI scraping (default: US)
SCRAPE_COUNTRY=US

# ─── Demo Mode ───────────────────────────────────────────────────────
# Set to "true" for the deployed Vercel demo (disables all writes)
DEMO_MODE=false

# ─── Database ────────────────────────────────────────────────────────
# Optional: override SQLite path (default: ./data/app.db)
# DATABASE_URL=./data/app.db
